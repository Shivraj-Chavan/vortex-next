{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
, "app/(website)/components/Footer.jsx", "app/(website)/components/ThemeToggle.jsx", "app/(website)/components/ThemeProvider.jsx", "app/(website)/page.jsx", "app/admin/(panel)/dashboard/page.jsx", "app/(website)/services/digital-marketing/page.jsx", "app/(website)/services/domain-hosting/page.tsx", "app/(website)/services/ecommerce/page.tsx"  ],
  "exclude": [
    "node_modules"
  ]
}
