{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
, "app/(website)/blog/page.jsx", "app/admin/(panel)/blogs/page.jsx", "app/(website)/components/Home/RecentBlog.jsx", "app/admin/(panel)/layout.jsx", "app/layout.jsx", "next.config.js", "app/(website)/components/Home/Hero.jsx", "app/(website)/components/Home/About.jsx", "app/(website)/components/Home/Services.jsx", "app/(website)/components/Home/Portfolio.jsx", "app/(website)/components/Home/Contact.jsx", "app/admin/(panel)/users/page.jsx", "app/admin/(panel)/contact/page.jsx", "tailwind.config.js", "app/(website)/components/Footer.jsx", "app/(website)/components/ThemeToggle.jsx", "app/(website)/components/ThemeProvider.jsx", "app/(website)/page.jsx", "app/admin/(panel)/dashboard/page.jsx"  ],
  "exclude": ["node_modules"]
}
